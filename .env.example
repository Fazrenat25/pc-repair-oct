# Database (PostgreSQL для production)
# Для локальной разработки можно использовать SQLite: file:./dev.db
DATABASE_URL="postgresql://user:password@localhost:5432/pc_repair?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_ADMIN_ID="your-telegram-admin-id"
TELEGRAM_PROXY=""

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Analytics (optional)
NEXT_PUBLIC_YANDEX_METRIKA_ID=""
NEXT_PUBLIC_GA_ID=""
